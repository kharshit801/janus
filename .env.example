# Janus — environment configuration
# Copy to .env and adjust for your deployment.

# API authentication key (required for /api/* endpoints)
JANUS_API_KEY=demo-key-finspark-2026

# Pipeline parameters
JANUS_SEED=42
JANUS_SESSIONS=800
JANUS_USERS=60

# PQC vault master secret (use KMS/HSM in production)
JANUS_MASTER_SECRET=change-this-in-production
